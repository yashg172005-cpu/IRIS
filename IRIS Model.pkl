_label)\n","\n","    #Compute accuracy on the test set\n","    test_accuracy[i] = knn.score(test_data, test_label)"],"metadata":{"id":"HnVXZS_tKWN_","executionInfo":{"status":"ok","timestamp":1777536455637,"user_tz":-330,"elapsed":26,"user":{"displayName":"yash","userId":"18346286857860489222"}}},"execution_count":67,"outputs":[]},{"cell_type":"code","source":["plt.figure(figsize=(10,6))\n","plt.title('KNN accuracy with varying number of neighbors',fontsize=20)\n","plt.plot(neighbors, test_accuracy, label='Testing Accuracy')\n","plt.plot(neighbors, train_accuracy, label='Training accuracy')\n","plt.legend(prop={'size': 20})\n","plt.xlabel('Number of neighbors',fontsize=20)\n","plt.ylabel('Accuracy',fontsize=20)\n","plt.xticks(fontsize=20)\n","plt.yticks(fontsize=20)\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":600},"id":"09D3jWwCKY_A","executionInfo":{"status":"ok","timestamp":1777536455644,"user_tz":-330,"elapsed":5,"user":{"displayName":"yash","userId":"18346286857860489222"}},"outputId":"4602a921-9da7-4d31-cad6-097caa1144d0"},"execution_count":68,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["knn = KNeighborsClassifier(n_neighbors=3)\n","\n","#Fit the model\n","knn.fit(train_data, train_label)\n","\n","#Compute accuracy on the training set\n","train_accuracy = knn.score(train_data, train_label)\n","\n","#Compute accuracy on the test set\n","test_accuracy = knn.score(test_data, test_label)"],"metadata":{"id":"ZzMUU8DsKjHS","executionInfo":{"status":"ok","timestamp":1777536455647,"user_tz":-330,"elapsed":1,"user":{"displayName":"yash","userId":"18346286857860489222"}}},"execution_count":69,"outputs":[]},{"cell_type":"code","source":["test_accuracy"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"aR8PtKyBKnkW","executionInfo":{"status":"ok","timestamp":1777536455658,"user_tz":-330,"elapsed":9,"user":{"displayName":"yash","userId":"18346286857860489222"}},"outputId":"d18a085c-46b6-46d6-c3a4-518329f00ebc"},"execution_count":70,"outputs":[{"output_type":"execute_result","data":{"text/plain":["1.0"]},"metadata":{},"execution_count":70}]},{"cell_type":"code","source":["prediction = knn.predict(test_data)"],"metadata":{"id":"efK8aTmAKqZS","executionInfo":{"status":"ok","timestamp":1777536455661,"user_tz":-330,"elapsed":2,"user":{"displayName":"yash","userId":"18346286857860489222"}}},"execution_count":71,"outputs":[]},{"cell_type":"code","source":["import itertools\n","from sklearn.metrics import confusion_matrix # Import confusion_matrix\n","\n","def plot_confusion_matrix(cm, classes,\n","                          normalize=False,\n","                          title='Confusion matrix',\n","                          cmap=plt.cm.Blues):\n","\n","\n","    plt.imshow(cm, interpolation='nearest', cmap=cmap)\n","    plt.title(title)\n","    plt.colorbar()\n","    tick_marks = np.arange(len(classes))\n","    plt.xticks(tick_marks, classes, rotation=45)\n","    plt.yticks(tick_marks, classes)\n","\n","    fmt = '.2f' if normalize else 'd'\n","    thresh = cm.max() / 2.\n","    for i, j in itertools.product(range(cm.shape[0]), range(cm.shape[1])):\n","        plt.text(j, i, format(cm[i, j], fmt),\n","                 horizontalalignment=\"center\",\n","                 color=\"white\" if cm[i, j] > thresh else \"black\")\n","\n","    plt.ylabel('True label',fontsize=30)\n","    plt.xlabel('Predicted label',fontsize=30)\n","    plt.tight_layout()\n","    plt.xticks(fontsize=18)\n","    plt.yticks(fontsize=18)\n","class_names = load_iris().target_names\n","\n","\n","# Compute confusion matrix\n","cnf_matrix = confusion_matrix(test_label, prediction)\n","np.set_printoptions(precision=2)\n","\n","# Plot non-normalized confusion matrix\n","plt.figure(figsize=(10,8))\n","plot_confusion_matrix(cnf_matrix, classes=class_names)\n","plt.title('Confusion Matrix',fontsize=30)\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":872},"id":"33swOeAmKtvY","executionInfo":{"status":"ok","timestamp":1777536456691,"user_tz":-330,"elapsed":1028,"user":{"displayName":"yash","userId":"18346286857860489222"}},"outputId":"ca755777-8ccd-4efb-f029-d4f285ef513a"},"execution_count":72,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x800 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["from sklearn.metrics import classification_report"],"metadata":{"id":"tUtFMezWLqmv","executionInfo":{"status":"ok","timestamp":1777536456697,"user_tz":-330,"elapsed":4,"user":{"displayName":"yash","userId":"18346286857860489222"}}},"execution_count":73,"outputs":[]},{"cell_type":"code","source":["print(classification_report(test_label, prediction))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"4Z4Mad2bLtzW","executionInfo":{"status":"ok","timestamp":1777536456709,"user_tz":-330,"elapsed":9,"user":{"displayName":"yash","userId":"18346286857860489222"}},"outputId":"346909aa-c329-40ad-9fc4-4214e5096c6b"},"execution_count":74,"outputs":[{"output_type":"stream","name":"stdout","text":["              precision    recall  f1-score   support\n","\n","         0.0       1.00      1.00      1.00        10\n","         1.0       1.00      1.00      1.00         9\n","         2.0       1.00      1.00      1.00        11\n","\n","    accuracy                           1.00        30\n","   macro avg       1.00      1.00      1.00        30\n","weighted avg       1.00      1.00      1.00        30\n","\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"YEwyDibALz-y","executionInfo":{"status":"ok","timestamp":1777536456714,"user_tz":-330,"elapsed":2,"user":{"displayName":"yash","userId":"18346286857860489222"}}},"execution_count":74,"outputs":[]}]}